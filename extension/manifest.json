{
  "manifest_version": 3,
  "name": "Is My Post Removed? for Reddit",
  "version": "0.3.1",
  "description": "See what Reddit hides. Instant status on every post you make.",
  "permissions": ["notifications"],
  "host_permissions": ["*://*.reddit.com/*"],
  "content_scripts": [
    {
      "matches": [
        "*://*.reddit.com/*",
        "*://old.reddit.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "PostGhost — See what Reddit hides",
    "default_popup": "popup.html"
  },
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
